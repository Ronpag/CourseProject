<Page x:Class="CRM.View.TasksPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:CRM.View"
      mc:Ignorable="d"
      Title="TasksPage" Height="450" Width="800">
    
      <Grid ShowGridLines="False">
        
            <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="10"/>
                  <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal">
                <StackPanel Margin="0,0,10,0">
                    <TextBlock Text="Task Name" />
                    <TextBox x:Name="NameTask" Width="150"/>
                </StackPanel>

                <StackPanel Margin="0,0,10,0">
                    <TextBlock Text="Client ID" />
                    <TextBox x:Name="ClientId" Width="100"/>
                </StackPanel>

                <StackPanel Margin="0,0,10,0">
                    <TextBlock Text="Worker ID" />
                    <TextBox x:Name="WorkerId" Width="100"/>
                </StackPanel>
                
                  <Button Content="Register" Width="70" Click="RegisterBtn"/>
                  <Button Content="Delete" Width="70" Click="DeleteBtn"/>
                  <Button Content="Update" Width="70" Click="UpdateBtn"/>
            </StackPanel>

            <ListBox x:Name="TasksList" Grid.Row="2"/>
        
      </Grid>
</Page>
