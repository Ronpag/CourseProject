<Page x:Class="CRM.View.UserListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:CRM.View"
      mc:Ignorable="d"
      Title="RegistrationPage" Height="450" Width="800">
    
    <Grid ShowGridLines="False">
        
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal">
            <Button Content="Register" Width="70" Click="RegisterBtn"/>
            <Button Content="Delete" Width="70" Click="DeleteBtn"/>
            <Button Content="Update" Width="70" Click="UpdateBtn"/>
            <Button Content="Details" Width="70" Click="DetailsBtn"/>
        </StackPanel>
        
        <ListBox x:Name="UsersList" Grid.Row="2" MouseDoubleClick="UsersList_MouseDoubleClick"/>
        
    </Grid>
</Page>