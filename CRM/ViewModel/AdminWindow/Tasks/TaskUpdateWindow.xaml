<Window x:Class="CRM.View.TaskUpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update Task"
        Height="450"
        Width="350"
        WindowStartupLocation="CenterScreen">

    <StackPanel Margin="20">

        <TextBlock Text="Task Name"/>
        <TextBox x:Name="TaskNameBox" Margin="0,5,0,10"/>

        <TextBlock Text="Description"/>
        <TextBox x:Name="DescriptionBox" Margin="0,5,0,10"
                 TextWrapping="Wrap" AcceptsReturn="True" MinHeight="50"/>

        <TextBlock Text="Client Id"/>
        <TextBox x:Name="ClientIdBox" Margin="0,5,0,10"/>

        <TextBlock Text="Worker Id"/>
        <TextBox x:Name="WorkerIdBox" Margin="0,5,0,10"/>

        <TextBlock Text="Status"/>
        <ComboBox x:Name="StatusBox" Margin="0,5,0,10"/>

        <Button Content="Save" Height="30" Click="SaveChangesBtn"/>
    </StackPanel>

</Window>
