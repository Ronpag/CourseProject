<Page x:Class="CRM.ViewModel.AdminWindow.TaskRequestsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="TaskRequestsPage">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal">
            <Button Content="Approve" Width="80" Margin="0,0,5,0" Click="ApproveBtn"/>
            <Button Content="Reject" Width="80" Click="RejectBtn"/>
        </StackPanel>

        <ListBox
            x:Name="RequestsList"
            Grid.Row="2"/>

    </Grid>

</Page>