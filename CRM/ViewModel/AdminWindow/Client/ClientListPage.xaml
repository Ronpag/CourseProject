<Page x:Class="CRM.View.ClientListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="ClientsPage">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal">
            <Button Content="Register" Width="70" Click="RegisterBtn"/>
            <Button Content="Delete" Width="70" Click="DeleteBtn"/>
            <Button Content="Update" Width="70" Click="UpdateBtn"/>
            <Button Content="Details" Width="70" Click="DetailsBtn"/>
        </StackPanel>
        <TextBox x:Name="SearchBox" Grid.Row="2" TextChanged="SearchBox_TextChanged"/>
        <ListBox x:Name="ClientsList" Grid.Row="4" MouseDoubleClick="ClientsList_MouseDoubleClick"/>

    </Grid>
</Page>