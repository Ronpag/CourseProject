<Window x:Class="CRM.View.UserUpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update User"
        Height="230"
        Width="350"
        WindowStartupLocation="CenterScreen">

    <StackPanel Margin="20">
        <TextBlock Text="Login"/>
        <TextBox x:Name="LoginBox" Margin="0,5,0,10"/>
        <TextBlock Text="Password"/>
        <TextBox x:Name="PasswordBox" Margin="0,5,0,20"/>
        <Button Content="Save" Height="30" Click="SaveChangesBtn"/>
    </StackPanel>

</Window>