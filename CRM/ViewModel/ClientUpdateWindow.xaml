<Window x:Class="CRM.View.ClientUpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update Client"
        Height="250"
        Width="350"
        WindowStartupLocation="CenterScreen">

    <StackPanel Margin="20">

        <TextBlock Text="Client Name"/>

        <TextBox x:Name="NameClientBox"
                 Margin="0,5,0,10"/>

        <TextBlock Text="Count Orders"/>

        <TextBox x:Name="CountOrdersBox"
                 Margin="0,5,0,20"/>

        <Button Content="Save"
                Height="30"
                Click="SaveChangesBtn"/>

    </StackPanel>

</Window>