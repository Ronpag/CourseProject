<Page
    x:Class="CRM.ViewModel.UserWindow.AvailableTasksPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ListBox x:Name="TasksList" MouseDoubleClick="TasksList_MouseDoubleClick"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0" HorizontalAlignment="Right">
            <Button Height="35" Width="100" Margin="0,0,10,0"
                    Content="Take task" Click="TakeTaskBtn"/>
            <Button Height="35" Width="100"
                    Content="Details" Click="DetailsBtn"/>
        </StackPanel>

    </Grid>

</Page>
