<Page
    x:Class="CRM.ViewModel.UserWindow.AvailableTasksPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ListBox
            x:Name="TasksList"/>

        <Button
            Grid.Row="1"
            Margin="0,10,0,0"
            Height="35"
            Content="Take task"
            Click="TakeTaskBtn"/>

    </Grid>

</Page>