<Window x:Class="CRM.ViewModel.UserWindow.ChangeTaskStatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Change Status" Height="350" Width="400">

    <Grid>
        <StackPanel Margin="15">

            <TextBlock Text="Status"/>
            <ComboBox x:Name="StatusBox" Margin="0,5,0,15"/>

            <TextBlock Text="Work Progress / Comment"/>
            <TextBox x:Name="CommentBox" MinHeight="80"
                     TextWrapping="Wrap" AcceptsReturn="True"
                     Margin="0,5,0,15"/>

            <Button Content="Send Request" Click="SaveBtn"/>

        </StackPanel>
    </Grid>
</Window>
