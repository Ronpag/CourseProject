<Window x:Class="CRM.ViewModel.UserWindow.ChangeTaskStatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Change Status" Height="400" Width="400">

    <Grid>
        <StackPanel Margin="15">

            <TextBlock Text="Status"/>
            <ComboBox x:Name="StatusBox" Margin="0,5,0,15"
                      SelectionChanged="StatusBox_SelectionChanged"/>

            <TextBlock Text="Work Progress / Comment"/>
            <TextBox x:Name="CommentBox" MinHeight="80"
                     TextWrapping="Wrap" AcceptsReturn="True"
                     Margin="0,5,0,15"/>

            <StackPanel x:Name="CompletionDatePanel" Visibility="Collapsed" Margin="0,0,0,15">
                <TextBlock Text="Completion Date (dd.MM.yyyy)"/>
                <TextBox x:Name="CompletionDateBox" Margin="0,5,0,0"/>
            </StackPanel>

            <Button Content="Send Request" Click="SaveBtn"/>

        </StackPanel>
    </Grid>
</Window>
