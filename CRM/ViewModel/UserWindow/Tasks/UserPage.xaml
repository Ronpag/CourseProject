<Page x:Class="CRM.ViewModel.UserWindow.UserPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="WorkerPage">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="My Tasks"
                   FontSize="18"
                   FontWeight="Bold"/>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal">

            <Button Content="Change Status"
                    Width="120"
                    Margin="0,0,10,0"
                    Click="ChangeStatusBtn"/>

            <Button Content="Details"
                    Width="80"
                    Click="DetailsBtn"/>

        </StackPanel>

        <TextBox x:Name="SearchBox" Grid.Row="3" TextChanged="SearchBox_TextChanged"/>

        <ListBox x:Name="TasksList"
                 Grid.Row="4"
                 Margin="0,10,0,0"
                 MouseDoubleClick="TasksList_MouseDoubleClick"/>

    </Grid>
</Page>