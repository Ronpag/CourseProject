<Window x:Class="CRM.ViewModel.UserWindow.CreateTaskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:CRM.ViewModel.UserWindow"
        mc:Ignorable="d"
        Title="CreateTaskWindow" Height="350" Width="400">
    
    <Grid>

        <StackPanel Margin="15">

            <TextBlock Text="Task Name"/>
            <TextBox x:Name="TaskNameBox"/>

            <TextBlock Margin="0,10,0,0"
                       Text="Client"/>

            <ComboBox x:Name="ClientsBox"
                      DisplayMemberPath="NameClient"/>

            <Button Margin="0,20,0,0"
                    Content="Create"
                    Click="CreateBtn"/>

        </StackPanel>
        
    </Grid>
</Window>
