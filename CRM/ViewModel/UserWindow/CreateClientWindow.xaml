<Window x:Class="CRM.ViewModel.UserWindow.CreateClientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:CRM.ViewModel.UserWindow"
        mc:Ignorable="d"
        Title="Create Client" Height="450" Width="400">
    
    <Grid>
    
        <StackPanel Margin="15">

            <TextBlock Text="Client Name"/>

            <TextBox x:Name="ClientNameBox"
                     Margin="0,5,0,15"/>

            <Button Content="Create"
                    Click="CreateBtn"/>

        </StackPanel>
        
    </Grid>
</Window>
