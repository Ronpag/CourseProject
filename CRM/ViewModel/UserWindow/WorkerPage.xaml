<Page x:Class="CRM.ViewModel.UserWindow.WorkerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="WorkerPage">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="My Tasks" FontSize="10" FontWeight="Bold" Margin="0,0,0,10"/>
        <ListBox x:Name="TasksList" Grid.Row="1"/>

    </Grid>
</Page>