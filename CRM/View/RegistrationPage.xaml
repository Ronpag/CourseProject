<Page x:Class="CRM.View.RegistrationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:CRM.View"
      mc:Ignorable="d"
      Title="RegistrationPage" Height="450" Width="800">
    
    <Grid ShowGridLines="true">
        
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal">
            <TextBox x:Name="Login" Width="150" Margin="0,0,10,0"/>
            <TextBox x:Name="Password" Width="150" Margin="0,0,10,0"/>
            <Button Content="Register" Width="100" Click="RegisterBtn"/>
            <Button Content="Delete" Width="100" Click="DeleteBtn"/>
            <Button Content="Update" Width="100" Click="UpdateBtn"/>
        </StackPanel>

        <ListBox x:Name="UsersList" Grid.Row="2"/>
        
    </Grid>
</Page>