<Page x:Class="CRM.ViewModel.AdminWindow.TaskRequestsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <Grid Margin="15">
        <TabControl>
            <TabItem Header="Status Requests">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <ListBox x:Name="RequestsList" MouseDoubleClick="RequestsList_MouseDoubleClick">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Margin" Value="0,0,0,4"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CardBorder}" HorizontalAlignment="Stretch">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource CardTitle}">
                                            <Run Text="Request #"/><Run Text="{Binding Id}"/>
                                        </TextBlock>
                                        <TextBlock Style="{StaticResource CardText}">
                                            <Run Text="Task #"/><Run Text="{Binding TaskId}"/>
                                        </TextBlock>
                                        <TextBlock Style="{StaticResource CardText}">
                                            <Run Text="{Binding RequestedStatus, StringFormat='Requested: {0}'}"/>
                                        </TextBlock>
                                        <TextBlock Style="{StaticResource CardText}" TextTrimming="CharacterEllipsis"
                                                   Text="{Binding Comment}" MaxHeight="32"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                                            <Button Content="Approve" Style="{StaticResource CardButton}" Click="ApproveBtn"/>
                                            <Button Content="Reject" Style="{StaticResource CardButton}" Click="RejectBtn"/>
                                            <Button Content="Details" Style="{StaticResource CardButton}" Click="RequestDetailsBtn"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>

            <TabItem Header="New Orders">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <ListBox x:Name="PendingOrdersList" MouseDoubleClick="PendingOrdersList_MouseDoubleClick">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Margin" Value="0,0,0,4"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CardBorder}" HorizontalAlignment="Stretch">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource CardTitle}">
                                            <Run Text="{Binding TaskName, Mode=OneWay}"/>
                                            <Run Text=" (ID: "/><Run Text="{Binding Id}"/><Run Text=")"/>
                                        </TextBlock>
                                        <TextBlock Style="{StaticResource CardText}">
                                            <Run Text="Status: "/><Run Text="{Binding Status}"/>
                                            <Run Text=" | Client ID: "/><Run Text="{Binding ClientId}"/>
                                        </TextBlock>
                                        <TextBlock Style="{StaticResource CardText}" TextTrimming="CharacterEllipsis"
                                                   Text="{Binding Description}" MaxHeight="32"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                                            <Button Content="Approve" Style="{StaticResource CardButton}" Click="ApproveOrderBtn"/>
                                            <Button Content="Delete" Style="{StaticResource CardButton}" Click="DeleteOrderBtn"/>
                                            <Button Content="Details" Style="{StaticResource CardButton}" Click="OrderDetailsBtn"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>

            <TabItem Header="Profile Requests">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <ListBox x:Name="ProfileRequestsList" MouseDoubleClick="ProfileRequestsList_MouseDoubleClick">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Margin" Value="0,0,0,4"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CardBorder}" HorizontalAlignment="Stretch">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource CardTitle}">
                                            <Run Text="Profile Request #"/><Run Text="{Binding Id}"/>
                                        </TextBlock>
                                        <TextBlock Style="{StaticResource CardText}">
                                            <Run Text="User ID: "/><Run Text="{Binding UserId}"/>
                                            <Run Text=" | Client ID: "/><Run Text="{Binding ClientId}"/>
                                        </TextBlock>
                                        <TextBlock Style="{StaticResource CardText}">
                                            <Run Text="New Email: "/><Run Text="{Binding NewEmail}"/>
                                        </TextBlock>
                                        <TextBlock Style="{StaticResource CardText}">
                                            <Run Text="New Phone: "/><Run Text="{Binding NewPhone}"/>
                                        </TextBlock>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                                            <Button Content="Approve" Style="{StaticResource CardButton}" Click="ApproveProfileBtn"/>
                                            <Button Content="Reject" Style="{StaticResource CardButton}" Click="RejectProfileBtn"/>
                                            <Button Content="Details" Style="{StaticResource CardButton}" Click="ProfileDetailsBtn"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Page>