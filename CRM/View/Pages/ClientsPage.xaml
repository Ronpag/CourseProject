<Page x:Class="CRM.ViewModel.UserWindow.ClientsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="24,20,24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Clients" Style="{StaticResource PageTitle}"/>

        <ListBox x:Name="ClientsList" Grid.Row="2" MouseDoubleClick="ClientsList_MouseDoubleClick">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Margin" Value="0,0,0,4"/>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource CardBorder}" HorizontalAlignment="Stretch">
                        <StackPanel>
                            <TextBlock Style="{StaticResource CardTitle}">
                                <Run Text="{Binding NameClient}"/>
                                <Run Text=" (ID: "/><Run Text="{Binding Id}"/><Run Text=")"/>
                            </TextBlock>
                            <TextBlock Style="{StaticResource CardText}">
                                <Run Text="Orders: "/><Run Text="{Binding CountOrders}"/>
                            </TextBlock>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                                <Button Content="Details" Style="{StaticResource CardButton}" Click="DetailsBtn"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Page>
