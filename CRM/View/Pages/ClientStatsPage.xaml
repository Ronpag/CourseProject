<Page x:Class="CRM.ViewModel.ClientWindow.ClientStatsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="ClientStatsPage">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="My Statistics" FontSize="20" FontWeight="Bold"/>
        <TextBlock x:Name="TotalOrders" Grid.Row="1" Margin="0,15,0,0" FontSize="14"/>
        <TextBlock x:Name="PendingOrders" Grid.Row="2" Margin="0,5,0,0" FontSize="14"/>
        <TextBlock x:Name="AvailableOrders" Grid.Row="3" Margin="0,5,0,0" FontSize="14"/>
        <TextBlock x:Name="AssignedOrders" Grid.Row="4" Margin="0,5,0,0" FontSize="14"/>
        <TextBlock x:Name="InProgressOrders" Grid.Row="5" Margin="0,5,0,0" FontSize="14"/>
        <TextBlock x:Name="CompletedOrders" Grid.Row="6" Margin="0,5,0,0" FontSize="14"/>
    </Grid>
</Page>
