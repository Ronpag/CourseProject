<Page x:Class="CRM.View.UserListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal">
            <Button Content="Register" Style="{StaticResource PrimaryButton}" Click="RegisterBtn"/>
        </StackPanel>

        <WrapPanel Grid.Row="2">
            <CheckBox x:Name="ChkUsers" Content="Users" Style="{StaticResource FilterCheckBox}" Checked="FilterChanged" Unchecked="FilterChanged"/>
            <CheckBox x:Name="ChkAdmins" Content="Admins" Style="{StaticResource FilterCheckBox}" Checked="FilterChanged" Unchecked="FilterChanged"/>
            <CheckBox x:Name="ChkActive" Content="Active" Style="{StaticResource FilterCheckBox}" Checked="FilterChanged" Unchecked="FilterChanged"/>
            <CheckBox x:Name="ChkInactive" Content="Inactive" Style="{StaticResource FilterCheckBox}" Checked="FilterChanged" Unchecked="FilterChanged"/>
            <CheckBox x:Name="ChkActiveTasks" Content="With Active Tasks" Style="{StaticResource FilterCheckBox}" Checked="FilterChanged" Unchecked="FilterChanged"/>
            <CheckBox x:Name="ChkCompletedTasks" Content="With Completed Tasks" Style="{StaticResource FilterCheckBox}" Checked="FilterChanged" Unchecked="FilterChanged"/>
        </WrapPanel>
        
        <ListBox x:Name="UsersList" Grid.Row="4" MouseDoubleClick="UsersList_MouseDoubleClick"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Margin" Value="0,0,0,4"/>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource CardBorder}" HorizontalAlignment="Stretch">
                        <StackPanel>
                            <TextBlock Style="{StaticResource CardTitle}">
                                <Run Text="{Binding UserName}"/>
                                <Run Text="("/><Run Text="{Binding Name}"/><Run Text=")"/>
                            </TextBlock>
                            <TextBlock Style="{StaticResource CardText}">
                                <Run Text="ID: "/><Run Text="{Binding Id}"/>
                                <Run Text=" | Active: "/><Run Text="{Binding IsActive}"/>
                            </TextBlock>
                            <TextBlock Style="{StaticResource CardText}">
                                <Run Text="Admin: "/><Run Text="{Binding IsAdmin}"/>
                            </TextBlock>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                                <Button Content="Delete" Style="{StaticResource CardButton}" Click="DeleteBtn"/>
                                <Button Content="Update" Style="{StaticResource CardButton}" Click="UpdateBtn"/>
                                <Button Content="Details" Style="{StaticResource CardButton}" Click="DetailsBtn"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        
    </Grid>
</Page>