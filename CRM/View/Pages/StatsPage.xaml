<Page x:Class="CRM.ViewModel.AdminWindow.StatsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="StatsPage">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="System Statistics" FontSize="20" FontWeight="Bold"/>
            <TextBlock x:Name="TotalUsers" Grid.Row="1" Margin="0,15,0,0" FontSize="14"/>
            <TextBlock x:Name="TotalClients" Grid.Row="2" Margin="0,5,0,0" FontSize="14"/>
            <TextBlock x:Name="TotalTasks" Grid.Row="3" Margin="0,5,0,0" FontSize="14"/>
            <TextBlock x:Name="PendingOrders" Grid.Row="4" Margin="0,5,0,0" FontSize="14"/>
            <TextBlock x:Name="AvailableTasks" Grid.Row="5" Margin="0,5,0,0" FontSize="14"/>
            <TextBlock x:Name="AssignedTasks" Grid.Row="6" Margin="0,5,0,0" FontSize="14"/>
            <TextBlock x:Name="InProgressTasks" Grid.Row="7" Margin="0,5,0,0" FontSize="14"/>
            <TextBlock x:Name="CompletedTasks" Grid.Row="8" Margin="0,5,0,0" FontSize="14"/>
            <TextBlock x:Name="PendingRequests" Grid.Row="9" Margin="0,5,0,0" FontSize="14"/>
            <TextBlock x:Name="ProfileRequests" Grid.Row="10" Margin="0,5,0,0" FontSize="14"/>
            <TextBlock x:Name="WorkerCount" Grid.Row="11" Margin="0,5,0,0" FontSize="14"/>
        </Grid>
    </ScrollViewer>
</Page>
