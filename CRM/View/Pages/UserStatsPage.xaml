<Page x:Class="CRM.ViewModel.UserWindow.UserStatsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20" Background="White">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="My Statistics" Style="{StaticResource PageTitle}"/>

            <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,12,0,0">
                <StackPanel>
                    <TextBlock Text="Date Filter" Style="{StaticResource CardTitle}"/>
                    <WrapPanel Margin="0,6,0,0">
                        <TextBlock Text="From:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <DatePicker x:Name="DateFrom" Width="130"/>
                        <TextBlock Text="To:" VerticalAlignment="Center" Margin="12,0,6,0"/>
                        <DatePicker x:Name="DateTo" Width="130"/>
                        <Button Content="Apply" Click="ApplyFilter" Width="80" Margin="12,0,0,0" Height="26"/>
                        <Button Content="Reset" Click="ResetFilter" Width="80" Margin="6,0,0,0" Height="26"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="2" Margin="0,15,0,0">
                <TextBlock x:Name="RegistrationDate" Margin="0,0,0,10" FontSize="14" FontWeight="SemiBold"/>
                <TextBlock x:Name="TotalTasks" Margin="0,0,0,5" FontSize="14"/>
                <TextBlock x:Name="AssignedTasks" Margin="0,0,0,5" FontSize="14"/>
                <TextBlock x:Name="InProgressTasks" Margin="0,0,0,5" FontSize="14"/>
                <TextBlock x:Name="CompletedTasks" Margin="0,0,0,5" FontSize="14"/>
                <TextBlock x:Name="PendingReview" Margin="0,0,0,5" FontSize="14"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
