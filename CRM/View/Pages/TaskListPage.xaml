<Page x:Class="CRM.View.TaskListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
      <Grid Margin="15">
        
            <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="10"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="10"/>
                  <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal">
                  <Button Content="Register" Style="{StaticResource PrimaryButton}" Click="RegisterBtn"/>
            </StackPanel>

            <WrapPanel Grid.Row="2">
                <TextBlock Text="Status:" Style="{StaticResource FilterLabel}"/>
                <CheckBox x:Name="ChkPending" Content="Pending" Style="{StaticResource FilterCheckBox}" Checked="FilterChanged" Unchecked="FilterChanged"/>
                <CheckBox x:Name="ChkAvailable" Content="Available" Style="{StaticResource FilterCheckBox}" Checked="FilterChanged" Unchecked="FilterChanged"/>
                <CheckBox x:Name="ChkAssigned" Content="Assigned" Style="{StaticResource FilterCheckBox}" Checked="FilterChanged" Unchecked="FilterChanged"/>
                <CheckBox x:Name="ChkInProgress" Content="InProgress" Style="{StaticResource FilterCheckBox}" Checked="FilterChanged" Unchecked="FilterChanged"/>
                <CheckBox x:Name="ChkCompleted" Content="Completed" Style="{StaticResource FilterCheckBox}" Checked="FilterChanged" Unchecked="FilterChanged"/>
                <TextBlock Text="From:" Style="{StaticResource FilterLabel}" Margin="10,0,5,0"/>
                <DatePicker x:Name="DateFrom" SelectedDateChanged="DateFilterChanged" Width="110" Style="{StaticResource FieldDatePicker}" Margin="0,0,10,0"/>
                <TextBlock Text="To:" Style="{StaticResource FilterLabel}"/>
                <DatePicker x:Name="DateTo" SelectedDateChanged="DateFilterChanged" Width="110" Style="{StaticResource FieldDatePicker}"/>
            </WrapPanel>

            <ListBox x:Name="TasksList" Grid.Row="4" MouseDoubleClick="TasksList_MouseDoubleClick">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Margin" Value="0,0,0,4"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardBorder}" HorizontalAlignment="Stretch">
                            <StackPanel>
                                <TextBlock Style="{StaticResource CardTitle}">
                                    <Run Text="{Binding TaskName, Mode=OneWay}"/>
                                    <Run Text=" (ID: "/><Run Text="{Binding Id}"/><Run Text=")"/>
                                </TextBlock>
                                <TextBlock Style="{StaticResource CardText}">
                                    <Run Text="Status: "/><Run Text="{Binding Status}"/>
                                    <Run Text=" | Client ID: "/><Run Text="{Binding ClientId}"/>
                                </TextBlock>
                                <TextBlock Style="{StaticResource CardText}">
                                    <Run Text="Worker ID: "/><Run Text="{Binding WorkerId}"/>
                                </TextBlock>
                                <TextBlock Style="{StaticResource CardText}">
                                    <Run Text="Start: "/><Run Text="{Binding StartDate, StringFormat={}{0:dd.MM.yyyy}}"/>
                                    <Run Text=" | Acceptance: "/><Run Text="{Binding AcceptanceDate, StringFormat={}{0:dd.MM.yyyy}}"/>
                                    <Run Text=" | Done: "/><Run Text="{Binding CompletionDate, StringFormat={}{0:dd.MM.yyyy}}"/>
                                </TextBlock>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                                    <Button Content="Delete" Style="{StaticResource CardButton}" Click="DeleteBtn"/>
                                    <Button Content="Update" Style="{StaticResource CardButton}" Click="UpdateBtn"/>
                                    <Button Content="Details" Style="{StaticResource CardButton}" Click="DetailsBtn"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        
      </Grid>
</Page>