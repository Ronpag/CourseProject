<Page x:Class="CRM.View.TaskListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:CRM.View"
      mc:Ignorable="d"
      Title="TasksPage" Height="450" Width="800">
    
      <Grid ShowGridLines="False">
        
            <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="10"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="10"/>
                  <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal">
                  <Button Content="Register" Width="70" Click="RegisterBtn"/>
                  <Button Content="Delete" Width="70" Click="DeleteBtn"/>
                  <Button Content="Update" Width="70" Click="UpdateBtn"/>
                  <Button Content="Details" Width="70" Click="DetailsBtn"/>
            </StackPanel>

            <WrapPanel Grid.Row="2">
                <TextBlock Text="Status:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <CheckBox x:Name="ChkPending" Content="Pending" VerticalAlignment="Center" Margin="0,0,10,0" Checked="FilterChanged" Unchecked="FilterChanged"/>
                <CheckBox x:Name="ChkAvailable" Content="Available" VerticalAlignment="Center" Margin="0,0,10,0" Checked="FilterChanged" Unchecked="FilterChanged"/>
                <CheckBox x:Name="ChkAssigned" Content="Assigned" VerticalAlignment="Center" Margin="0,0,10,0" Checked="FilterChanged" Unchecked="FilterChanged"/>
                <CheckBox x:Name="ChkInProgress" Content="InProgress" VerticalAlignment="Center" Margin="0,0,10,0" Checked="FilterChanged" Unchecked="FilterChanged"/>
                <CheckBox x:Name="ChkCompleted" Content="Completed" VerticalAlignment="Center" Margin="0,0,10,0" Checked="FilterChanged" Unchecked="FilterChanged"/>
                <TextBlock Text="From:" VerticalAlignment="Center" Margin="10,0,5,0"/>
                <DatePicker x:Name="DateFrom" SelectedDateChanged="DateFilterChanged" Width="110" Margin="0,0,10,0"/>
                <TextBlock Text="To:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <DatePicker x:Name="DateTo" SelectedDateChanged="DateFilterChanged" Width="110"/>
            </WrapPanel>

            <ListBox x:Name="TasksList" Grid.Row="4" MouseDoubleClick="TasksList_MouseDoubleClick"/>
        
      </Grid>
</Page>
