<Page
    x:Class="CRM.ViewModel.UserWindow.AvailableTasksPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="24,20,24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Available Tasks" Style="{StaticResource PageTitle}"/>

        <ListBox x:Name="TasksList" Grid.Row="2" MouseDoubleClick="TasksList_MouseDoubleClick">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Margin" Value="0,0,0,4"/>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource CardBorder}" HorizontalAlignment="Stretch">
                        <StackPanel>
                            <TextBlock Style="{StaticResource CardTitle}">
                                <Run Text="{Binding TaskName, Mode=OneWay}"/>
                                <Run Text=" (ID: "/><Run Text="{Binding Id}"/><Run Text=")"/>
                            </TextBlock>
                            <TextBlock Style="{StaticResource CardText}">
                                <Run Text="Status: "/><Run Text="{Binding Status}"/>
                                <Run Text=" | Client ID: "/><Run Text="{Binding ClientId}"/>
                            </TextBlock>
                            <TextBlock Style="{StaticResource CardText}" TextTrimming="CharacterEllipsis"
                                       Text="{Binding Description}" MaxHeight="32"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                                <Button Content="Take Task" Style="{StaticResource SuccessButton}" Click="TakeTaskBtn"/>
                                <Button Content="Details" Style="{StaticResource CardButton}" Click="DetailsBtn"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Page>
