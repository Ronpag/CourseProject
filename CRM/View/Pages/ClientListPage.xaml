<Page x:Class="CRM.View.ClientListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal">
            <Button Content="Register" Width="70" Click="RegisterBtn"/>
        </StackPanel>

        <ListBox x:Name="ClientsList" Grid.Row="2" MouseDoubleClick="ClientsList_MouseDoubleClick">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Margin" Value="0,0,0,4"/>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource CardBorder}" HorizontalAlignment="Stretch">
                        <StackPanel>
                            <TextBlock Style="{StaticResource CardTitle}">
                                <Run Text="{Binding NameClient}"/>
                                <Run Text=" (ID: "/><Run Text="{Binding Id}"/><Run Text=")"/>
                            </TextBlock>
                            <TextBlock Style="{StaticResource CardText}">
                                <Run Text="Orders: "/><Run Text="{Binding CountOrders}"/>
                            </TextBlock>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                                <Button Content="Delete" Style="{StaticResource CardButton}" Click="DeleteBtn"/>
                                <Button Content="Update" Style="{StaticResource CardButton}" Click="UpdateBtn"/>
                                <Button Content="Details" Style="{StaticResource CardButton}" Click="DetailsBtn"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

    </Grid>
</Page>