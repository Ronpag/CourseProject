<Window x:Class="CRM.UserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CRM"
        mc:Ignorable="d"
        Title="CRM" Height="450" Width="800">
    <Grid ShowGridLines="False">
        
        <Grid.RowDefinitions>
            <RowDefinition Height="0.5*"/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        
        
        <Button Grid.Row="1" Grid.Column="0" Background="AliceBlue"
                Content="Worker" Click="UserPageBtn"/>
        <Button Grid.Row="2" Grid.Column="0" Background="AliceBlue"
                Content="Available Tasks" Click="AvailableBtn"/>
        <Button Grid.Row="3" Grid.Column="0" Background="AliceBlue"
                Content="Clients" Click="ClientsBtn"/>
        <Button Grid.Row="4" Grid.Column="0" Background="AliceBlue"
                Content="Stats" Click="StatsBtn"/>
        <Button Grid.Row="5" Grid.Column="0" Background="AliceBlue"
                Content="Profile" Click="ProfileBtn"/>
        
        <Grid Grid.Row="1" Grid.Column="1" Grid.RowSpan="9" Grid.ColumnSpan="4" x:Name="AppArea" Background="LightGray">
            <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>
        </Grid>
        
        <Label Content="User Panel"/>
        <Button Grid.Row="0" Grid.Column="4" Click="BackBtn" Content="Exit"/>
        
    </Grid>
</Window>
