<Window x:Class="CRM.View.FSWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="CRM" 
        Height="450" Width="400"
        WindowStartupLocation="CenterScreen">
    
    <Grid ShowGridLines="False">
        
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="0.2*"/>
            <RowDefinition/>
            <RowDefinition Height="0.2*"/>
            <RowDefinition/>
            <RowDefinition Height="0.1*"/>
            <RowDefinition Height="0.4*"/>
        </Grid.RowDefinitions>
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        
        <Label Grid.Row="0" Grid.Column="0">First StartUp</Label>
        <Label Grid.Row="0" Grid.Column="1">Write login and password</Label>
        
        <Label Grid.Row="1" Grid.Column="0">User Name</Label>
        <TextBox Name="FUserName" Grid.Row="2" Grid.Column="0"></TextBox>

        <Label Grid.Row="3" Grid.Column="0">Login</Label>
        <Label Grid.Row="3" Grid.Column="1">Password</Label>
        
        <TextBox Name="FLogin" Grid.Row="4" Grid.Column="0"></TextBox>
        <TextBox Name="FPassword" Grid.Row="4" Grid.Column="1"></TextBox>

        <Button Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="3" Click="FirstLoginBtn">START</Button>
        
    </Grid>
</Window>
