<Window x:Class="CRM.View.UserProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="CRM" 
        MinHeight="450"
        Height="450" Width="380"
        WindowStartupLocation="CenterScreen">

    <StackPanel Margin="15">

        <TextBlock Text="Profile Change Request" Style="{StaticResource PageTitle}"/>
        <TextBlock Text="Changes need admin approval." Foreground="Gray" Margin="0,0,0,15"/>
        <TextBlock Text="User Name" Style="{StaticResource FieldLabel}"/>
        <TextBlock x:Name="UserNameText" FontWeight="Bold" Margin="0,2,0,10"/>
        <TextBlock Text="Login" Style="{StaticResource FieldLabel}"/>
        <TextBlock x:Name="LoginText" FontWeight="Bold" Margin="0,2,0,10"/>
        <TextBlock Text="Email" Style="{StaticResource FieldLabel}"/>
        <TextBox x:Name="EmailBox" Style="{StaticResource FieldTextBox}"/>
        <TextBlock Text="Phone" Style="{StaticResource FieldLabel}"/>
        <TextBox x:Name="PhoneBox" Style="{StaticResource FieldTextBox}"/>
        <TextBlock Text="Position" Style="{StaticResource FieldLabel}"/>
        <TextBox x:Name="PositionBox" Style="{StaticResource FieldTextBox}"/>
        <Button Content="Submit for Approval" Style="{StaticResource PrimaryButton}" Click="SubmitBtn"/>

    </StackPanel>

</Window>
