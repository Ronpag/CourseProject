<Window x:Class="CRM.ViewModel.UserWindow.ChangeTaskStatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="CRM" 
        Height="400" Width="400"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <StackPanel Margin="15">

            <TextBlock Text="Status"/>
            <ComboBox x:Name="StatusBox" Margin="0,5,0,15"/>

            <TextBlock Text="Work Progress / Comment"/>
            <TextBox x:Name="CommentBox" MinHeight="80"
                     TextWrapping="Wrap" AcceptsReturn="True"
                     Margin="0,5,0,15"/>

            <Button Content="Send Request" Click="SaveBtn"/>

        </StackPanel>
    </Grid>
</Window>
