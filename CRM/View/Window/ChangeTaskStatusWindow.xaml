<Window x:Class="CRM.ViewModel.UserWindow.ChangeTaskStatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="CRM" 
        MinHeight="300"
        Height="300" Width="400"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <StackPanel Margin="15">

            <TextBlock Text="Status" Style="{StaticResource FieldLabel}"/>
            <ComboBox x:Name="StatusBox" Style="{StaticResource FieldComboBox}"/>

            <TextBlock Text="Work Progress / Comment" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="CommentBox" MinHeight="80"
                     TextWrapping="Wrap" AcceptsReturn="True"
                     Style="{StaticResource FieldTextBox}"/>

            <Button Content="Send Request" Style="{StaticResource PrimaryButton}" Click="SaveBtn"/>

        </StackPanel>
    </Grid>
</Window>
