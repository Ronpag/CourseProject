<Window x:Class="CRM.ViewModel.UserWindow.CreateTaskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="CRM" 
        Height="420" Width="400"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <StackPanel Margin="15">

            <TextBlock Text="Task Name"/>
            <TextBox x:Name="TaskNameBox"/>

            <TextBlock Margin="0,10,0,0" Text="Description"/>
            <TextBox x:Name="DescriptionBox" MinHeight="60"
                     TextWrapping="Wrap" AcceptsReturn="True"
                     Margin="0,5,0,10"/>

            <TextBlock Margin="0,10,0,0" Text="Client"/>
            <ComboBox x:Name="ClientsBox"
                      DisplayMemberPath="NameClient"/>

            <Button Margin="0,20,0,0"
                    Content="Create"
                    Click="CreateBtn"/>

        </StackPanel>
    </Grid>
</Window>
