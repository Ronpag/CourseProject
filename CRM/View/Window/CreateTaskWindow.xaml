<Window x:Class="CRM.View.CreateTaskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Icon="pack://application:,,,/Assets/relic.ico"
        Title="CRM"
        MinHeight="500" MinWidth="400"
        Height="500" Width="400"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Create Task" HorizontalAlignment="Center" Style="{StaticResource PageTitle}"/>

        <TextBlock Grid.Row="1" Text="Task Name" Style="{StaticResource FieldLabel}"/>
        <TextBox x:Name="TaskNameBox" Grid.Row="2" Style="{StaticResource FieldTextBox}"/>

        <TextBlock Grid.Row="3" Text="Description" Style="{StaticResource FieldLabel}"/>
        <TextBox x:Name="DescriptionBox" Grid.Row="4" Style="{StaticResource FieldTextBox}"
                 TextWrapping="Wrap" AcceptsReturn="True" MinHeight="70" Height="Auto"/>

        <TextBlock Grid.Row="5" Text="Client" Style="{StaticResource FieldLabel}"/>
        <ComboBox x:Name="ClientsBox" Grid.Row="6" Style="{StaticResource FieldComboBox}"
                  DisplayMemberPath="NameClient"/>

        <CheckBox x:Name="AssignUserCheckBox"
                  Grid.Row="7" Content="Assign User" Style="{StaticResource FieldCheckBox}"
                  Checked="AssignUserChanged"
                  Unchecked="AssignUserChanged"/>

        <ComboBox x:Name="UsersBox" Grid.Row="8" Style="{StaticResource FieldComboBox}"
                  DisplayMemberPath="UserName"
                  Visibility="Collapsed"/>

        <Button Grid.Row="9" Content="Register" Style="{StaticResource PrimaryButton}" Click="RegisterBtn" Height="36"/>
    </Grid>
</Window>
