<Window x:Class="CRM.View.CreateUserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="CRM" 
        MinHeight="500"
        Height="500" Width="380"
        WindowStartupLocation="CenterScreen">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="15">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="User Name" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="UserNameBox" Grid.Row="1" Style="{StaticResource FieldTextBox}"/>

            <TextBlock Grid.Row="2" Text="Login" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="LoginBox" Grid.Row="3" Style="{StaticResource FieldTextBox}"/>

            <TextBlock Grid.Row="4" Text="Password" Style="{StaticResource FieldLabel}"/>
            <PasswordBox x:Name="PasswordBox" Grid.Row="5" Style="{StaticResource FieldPasswordBox}"/>

            <TextBlock Grid.Row="6" Text="Email" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="EmailBox" Grid.Row="7" Style="{StaticResource FieldTextBox}"/>

            <TextBlock Grid.Row="8" Text="Phone" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="PhoneBox" Grid.Row="9" Style="{StaticResource FieldTextBox}"/>

            <TextBlock Grid.Row="10" Text="Position" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="PositionBox" Grid.Row="11" Style="{StaticResource FieldTextBox}"/>

            <CheckBox x:Name="ActiveCheckBox" Grid.Row="12" Content="Active" IsChecked="True" Style="{StaticResource FieldCheckBox}"/>

            <Button Grid.Row="13" Content="Register" Style="{StaticResource PrimaryButton}" Click="RegisterBtn"/>
        </Grid>
    </ScrollViewer>

</Window>
