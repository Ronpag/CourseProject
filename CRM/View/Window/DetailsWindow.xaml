<Window x:Class="CRM.View.DetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Icon="pack://application:,,,/Assets/relic.ico"
        Title="CRM"
        MinHeight="460" MinWidth="500"
        Height="460" Width="500"
        WindowStartupLocation="CenterScreen">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20">
        <Border Style="{StaticResource CardBorder}" Padding="20">
            <TextBlock x:Name="DetailsContent" TextWrapping="Wrap" FontSize="14"
                       LineHeight="24" Foreground="{StaticResource TextPrimaryBrush}"/>
        </Border>
    </ScrollViewer>
</Window>
