<Window x:Class="CRM.ViewModel.ClientWindow.RegisterTaskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="CRM" 
        Height="350" Width="400"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <StackPanel Margin="15">

            <TextBlock Text="Order Name"/>
            <TextBox x:Name="OrderNameBox" Margin="0,5,0,10"/>

            <TextBlock Text="Description"/>
            <TextBox x:Name="DescriptionBox" MinHeight="80"
                     TextWrapping="Wrap" AcceptsReturn="True"
                     Margin="0,5,0,15"/>

            <Button Content="Create" Click="CreateBtn"/>

        </StackPanel>
    </Grid>
</Window>
