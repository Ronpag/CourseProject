<Window x:Class="CRM.ViewModel.ClientWindow.RegisterTaskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Icon="pack://application:,,,/Assets/relic.ico"
        Title="CRM"
        MinHeight="340" MinWidth="400"
        Height="340" Width="400"
        WindowStartupLocation="CenterScreen">

    <Border Margin="12" Background="{StaticResource SurfaceBrush}"
            CornerRadius="12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <StackPanel Margin="24,20">
            <TextBlock Text="New Order" HorizontalAlignment="Center" Style="{StaticResource PageTitle}"/>

            <TextBlock Text="Order Name" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="OrderNameBox" Style="{StaticResource FieldTextBox}"/>

            <TextBlock Text="Description" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="DescriptionBox" MinHeight="80"
                     TextWrapping="Wrap" AcceptsReturn="True"
                     Style="{StaticResource FieldTextBox}" Height="Auto"/>

            <Button Content="Create Order" Style="{StaticResource PrimaryButton}" Click="CreateBtn" Height="36"/>
        </StackPanel>
    </Border>
</Window>
