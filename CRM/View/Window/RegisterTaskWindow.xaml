<Window x:Class="CRM.ViewModel.ClientWindow.RegisterTaskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="CRM" 
        MinHeight="300"
        Height="300" Width="400"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <StackPanel Margin="15">

            <TextBlock Text="Order Name" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="OrderNameBox" Style="{StaticResource FieldTextBox}"/>

            <TextBlock Text="Description" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="DescriptionBox" MinHeight="80"
                     TextWrapping="Wrap" AcceptsReturn="True"
                     Style="{StaticResource FieldTextBox}"/>

            <Button Content="Create" Style="{StaticResource PrimaryButton}" Click="CreateBtn"/>

        </StackPanel>
    </Grid>
</Window>
