<Window x:Class="CRM.View.ClientUpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="CRM" 
        Height="320" Width="350"
        WindowStartupLocation="CenterScreen">

    <StackPanel Margin="20">

        <TextBlock Text="Client Name"/>
        <TextBox x:Name="NameClientBox" Margin="0,5,0,10"/>

        <TextBlock Text="Login"/>
        <TextBox x:Name="LoginBox" Margin="0,5,0,10"/>

        <TextBlock Text="Password"/>
        <TextBox x:Name="PasswordBox" Margin="0,5,0,10"/>

        <TextBlock Text="Count Orders"/>
        <TextBox x:Name="CountOrdersBox" Margin="0,5,0,10"/>

        <Button Content="Save" Height="30" Click="SaveChangesBtn"/>

    </StackPanel>

</Window>
