<Window x:Class="CRM.View.UserUpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Icon="pack://application:,,,/Assets/relic.ico"
        Title="CRM"
        MinHeight="600" MinWidth="400"
        Height="600" Width="400"
        WindowStartupLocation="CenterScreen">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,24">
        <StackPanel>
            <TextBlock Text="Update User" Style="{StaticResource PageTitle}"/>

            <TextBlock Text="User Name" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="UserNameBox" Style="{StaticResource FieldTextBox}"/>

            <TextBlock Text="Login" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="LoginBox" Style="{StaticResource FieldTextBox}"/>

            <TextBlock Text="Password" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="PasswordBox" Style="{StaticResource FieldTextBox}"/>

            <TextBlock Text="Email" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="EmailBox" Style="{StaticResource FieldTextBox}"/>

            <TextBlock Text="Phone" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="PhoneBox" Style="{StaticResource FieldTextBox}"/>

            <TextBlock Text="Position" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="PositionBox" Style="{StaticResource FieldTextBox}"/>

            <CheckBox x:Name="IsActiveBox" Content="Active User"
                      Style="{StaticResource FieldCheckBox}" Margin="0,0,0,8"/>

            <Button Content="Save Changes" Style="{StaticResource PrimaryButton}" Click="SaveChangesBtn" Height="36"/>
        </StackPanel>
    </ScrollViewer>
</Window>
