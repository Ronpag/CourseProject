<Window x:Class="CRM.View.UserUpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="CRM" 
        MinHeight="300"
        Height="300" Width="350"
        WindowStartupLocation="CenterScreen">

    <StackPanel Margin="15">

        <TextBlock Text="User Name" Style="{StaticResource FieldLabel}"/>
        <TextBox x:Name="UserNameBox" Style="{StaticResource FieldTextBox}"/>

        <TextBlock Text="Login" Style="{StaticResource FieldLabel}"/>
        <TextBox x:Name="LoginBox" Style="{StaticResource FieldTextBox}"/>

        <TextBlock Text="Password" Style="{StaticResource FieldLabel}"/>
        <TextBox x:Name="PasswordBox" Style="{StaticResource FieldTextBox}"/>

        <CheckBox x:Name="IsActiveBox"
                  Content="Active user"
                  Style="{StaticResource FieldCheckBox}"/>

        <Button Content="Save"
                Style="{StaticResource PrimaryButton}"
                Click="SaveChangesBtn"/>
    </StackPanel>

</Window>
