<Window x:Class="CRM.View.UserUpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="CRM" 
        Height="320" Width="350"
        WindowStartupLocation="CenterScreen">

    <StackPanel Margin="20">

        <TextBlock Text="User Name"/>
        <TextBox x:Name="UserNameBox" Margin="0,5,0,10"/>

        <TextBlock Text="Login"/>
        <TextBox x:Name="LoginBox" Margin="0,5,0,10"/>

        <TextBlock Text="Password"/>
        <TextBox x:Name="PasswordBox" Margin="0,5,0,10"/>

        <CheckBox x:Name="IsActiveBox"
                  Content="Active user"
                  Margin="0,0,0,15"/>

        <Button Content="Save"
                Height="30"
                Click="SaveChangesBtn"/>
    </StackPanel>

</Window>
