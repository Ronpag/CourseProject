<Window x:Class="CRM.View.ClientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="CRM" 
        MinHeight="410" MinWidth="950"
        Height="410" Width="950"
        WindowStartupLocation="CenterScreen">
    
    <Grid ShowGridLines="False">

        <Grid.RowDefinitions>
            <RowDefinition Height="0.5*"/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Button Grid.Row="1" Grid.Column="0" Background="AliceBlue"
                Content="My Orders" Click="MyOrdersBtn"/>

        <Button Grid.Row="2" Grid.Column="0" Background="AliceBlue"
                Content="Create Order" Click="CreateOrderBtn"/>

        <Button Grid.Row="3" Grid.Column="0" Background="AliceBlue"
                Content="Stats" Click="StatsBtn"/>

        <Button Grid.Row="4" Grid.Column="0" Background="AliceBlue"
                Content="Profile" Click="ProfileBtn"/>

        <Grid Grid.Row="1" Grid.Column="1" Grid.RowSpan="9" Grid.ColumnSpan="4" x:Name="AppArea" Background="LightGray">
            <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>
        </Grid>

        <Button Grid.Row="0" Grid.Column="4" Click="BackBtn" Content="Exit"/>

    </Grid>
</Window>
