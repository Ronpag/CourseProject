<Window x:Class="CRM.View.ClientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Icon="pack://application:,,,/Assets/relic.ico"
        Title="CRM"
        MinHeight="500" MinWidth="1100"
        Height="550" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Margin="16,20,16,24">
                    <TextBlock Text="CRM" FontSize="22" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Client Portal" FontSize="12" Foreground="#94A3B8" Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,0,0,0">
                    <Button Content="My Orders" Style="{StaticResource SidebarButton}" Click="MyOrdersBtn"/>
                    <Button Content="Create Order" Style="{StaticResource SidebarButton}" Click="CreateOrderBtn"/>
                    <Button Content="Stats" Style="{StaticResource SidebarButton}" Click="StatsBtn"/>
                    <Button Content="Profile" Style="{StaticResource SidebarButton}" Click="ProfileBtn"/>
                </StackPanel>

                <Button Grid.Row="2" Content="Exit" Style="{StaticResource SidebarButton}"
                        Click="BackBtn" Margin="0,0,0,12"/>
            </Grid>
        </Border>

        <Grid Grid.Column="1" x:Name="AppArea">
            <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>
        </Grid>
    </Grid>
</Window>
