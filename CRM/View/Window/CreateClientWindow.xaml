<Window x:Class="CRM.ViewModel.UserWindow.CreateClientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="CRM" 
        Height="350" Width="400"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <StackPanel Margin="15">

            <TextBlock Text="Client Name"/>
            <TextBox x:Name="ClientNameBox" Margin="0,5,0,10"/>

            <TextBlock Text="Login"/>
            <TextBox x:Name="LoginBox" Margin="0,5,0,10"/>

            <TextBlock Text="Password"/>
            <PasswordBox x:Name="PasswordBox" Margin="0,5,0,10"/>

            <Button Content="Create" Margin="0,10,0,0" Click="CreateBtn"/>

        </StackPanel>
    </Grid>
</Window>
