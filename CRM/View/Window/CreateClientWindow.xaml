<Window x:Class="CRM.View.CreateClientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Icon="pack://application:,,,/Assets/relic.ico"
        Title="CRM"
        MinHeight="600" MinWidth="400"
        Height="600" Width="400"
        WindowStartupLocation="CenterScreen">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Create Client" HorizontalAlignment="Center" Style="{StaticResource PageTitle}"/>

            <TextBlock Grid.Row="1" Text="Client Name" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="ClientNameBox" Grid.Row="2" Style="{StaticResource FieldTextBox}"/>

            <TextBlock Grid.Row="3" Text="Login" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="LoginBox" Grid.Row="4" Style="{StaticResource FieldTextBox}"/>

            <TextBlock Grid.Row="5" Text="Password" Style="{StaticResource FieldLabel}"/>
            <PasswordBox x:Name="PasswordBox" Grid.Row="6" Style="{StaticResource FieldPasswordBox}"/>

            <TextBlock Grid.Row="7" Text="Email" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="EmailBox" Grid.Row="8" Style="{StaticResource FieldTextBox}"/>

            <TextBlock Grid.Row="9" Text="Phone" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="PhoneBox" Grid.Row="10" Style="{StaticResource FieldTextBox}"/>

            <TextBlock Grid.Row="11" Text="Address" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="AddressBox" Grid.Row="12" Style="{StaticResource FieldTextBox}"/>

            <Button Grid.Row="13" Content="Create" Style="{StaticResource PrimaryButton}" Click="CreateBtn" Height="36"/>
        </Grid>
    </ScrollViewer>
</Window>
