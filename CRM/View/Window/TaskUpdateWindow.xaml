<Window x:Class="CRM.View.TaskUpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update Task"
        Height="550"
        Width="350"
        WindowStartupLocation="CenterScreen">

    <StackPanel Margin="20">

        <TextBlock Text="Task Name"/>
        <TextBox x:Name="TaskNameBox" Margin="0,5,0,10"/>

        <TextBlock Text="Description"/>
        <TextBox x:Name="DescriptionBox" Margin="0,5,0,10"
                 TextWrapping="Wrap" AcceptsReturn="True" MinHeight="40"/>

        <TextBlock Text="Client Id"/>
        <TextBox x:Name="ClientIdBox" Margin="0,5,0,10"/>

        <TextBlock Text="User Id"/>
        <TextBox x:Name="UserIdBox" Margin="0,5,0,10"/>

        <TextBlock Text="Status"/>
        <ComboBox x:Name="StatusBox" Margin="0,5,0,10"/>

        <TextBlock Text="Start Date (dd.MM.yyyy)"/>
        <TextBox x:Name="StartDateBox" Margin="0,5,0,10"/>

        <TextBlock Text="Acceptance Date (dd.MM.yyyy)"/>
        <TextBox x:Name="AcceptanceDateBox" Margin="0,5,0,10"/>

        <TextBlock Text="Completion Date (dd.MM.yyyy)"/>
        <TextBox x:Name="CompletionDateBox" Margin="0,5,0,10"/>

        <Button Content="Save" Height="30" Click="SaveChangesBtn"/>

    </StackPanel>

</Window>
