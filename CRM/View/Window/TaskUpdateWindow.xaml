<Window x:Class="CRM.View.TaskUpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="CRM" 
        MinHeight="570"
        Height="570" Width="350"
        WindowStartupLocation="CenterScreen">

    <StackPanel Margin="15">

        <TextBlock Text="Task Name" Style="{StaticResource FieldLabel}"/>
        <TextBox x:Name="TaskNameBox" Style="{StaticResource FieldTextBox}"/>

        <TextBlock Text="Description" Style="{StaticResource FieldLabel}"/>
        <TextBox x:Name="DescriptionBox" Style="{StaticResource FieldTextBox}"
                 TextWrapping="Wrap" AcceptsReturn="True" MinHeight="40"/>

        <TextBlock Text="Client Id" Style="{StaticResource FieldLabel}"/>
        <TextBox x:Name="ClientIdBox" Style="{StaticResource FieldTextBox}"/>

        <TextBlock Text="User Id" Style="{StaticResource FieldLabel}"/>
        <TextBox x:Name="UserIdBox" Style="{StaticResource FieldTextBox}"/>

        <TextBlock Text="Status" Style="{StaticResource FieldLabel}"/>
        <ComboBox x:Name="StatusBox" Style="{StaticResource FieldComboBox}"/>

        <TextBlock Text="Start Date (dd.MM.yyyy)" Style="{StaticResource FieldLabel}"/>
        <TextBox x:Name="StartDateBox" Style="{StaticResource FieldTextBox}"/>

        <TextBlock Text="Acceptance Date (dd.MM.yyyy)" Style="{StaticResource FieldLabel}"/>
        <TextBox x:Name="AcceptanceDateBox" Style="{StaticResource FieldTextBox}"/>

        <TextBlock Text="Completion Date (dd.MM.yyyy)" Style="{StaticResource FieldLabel}"/>
        <TextBox x:Name="CompletionDateBox" Style="{StaticResource FieldTextBox}"/>

        <Button Content="Save" Style="{StaticResource PrimaryButton}" Click="SaveChangesBtn"/>

    </StackPanel>

</Window>
